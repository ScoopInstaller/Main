            "hash": "ba97d8b66d627c85f98bf99a7366b5cffe977a0934b095b485b6e36e318d7de4",
            "extract_dir": "PFiles64\\psqlODBC\\1800"
        },
        "32bit": {
            "url": "https://ftp.postgresql.org/pub/odbc/releases/REL-18_00_0000/psqlodbc_x86.msi",
