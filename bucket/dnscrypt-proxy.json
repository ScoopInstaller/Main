            "hash": "15f0c8f1f40620a54ddfd8752c327dabe1146f84618d68874f79c4f52490b396",
            "extract_dir": "win64"
        },
        "32bit": {
            "url": "https://github.com/DNSCrypt/dnscrypt-proxy/releases/download/2.1.18/dnscrypt-proxy-win32-2.1.18.zip",
