{
    "version": "1.91.0",
    "description": "Boost C++ Libraries",
    "homepage": "https://www.boost.org/",
    "license": "BSL-1.0",
    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/project/boost/boost-binaries/1.91.0/boost_1_91_0-msvc-14.5-64.exe",
            "hash": "sha1:0d80627afe5f92b391ffb60b5b28b0e226ca28ee"
        },
        "32bit": {
            "url": "https://downloads.sourceforge.net/project/boost/boost-binaries/1.91.0/boost_1_91_0-msvc-14.5-32.exe",
            "hash": "sha1:cac1bcc18a4b4d0288f8e1d0856d8b8bfda9d083"
        }
    },
    "innosetup": true,
    "pre_install": "Get-ChildItem \"$dir/lib$($architecture.Substring(0, 2))-msvc-*.*\" | Rename-Item -NewName lib",
    "env_set": {
        "BOOST_ROOT": "$dir",
        "Boost_INCLUDE_DIR": "$dir\\boost"
    },
    "checkver": {
        "sourceforge": "boost/boost-binaries",
        "regex": "([\\d.]+)+/boost_(?:[\\d_]+)-msvc-(?<msvc>[\\d.]+)-64\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/project/boost/boost-binaries/$version/boost_$underscoreVersion-msvc-$matchMsvc-64.exe"
            },
            "32bit": {
                "url": "https://downloads.sourceforge.net/project/boost/boost-binaries/$version/boost_$underscoreVersion-msvc-$matchMsvc-32.exe"
            }
        }
    }
}
