    "bin": "shinyproxy.jar",
    "pre_install": "if (!(Test-Path \"$persist_dir\\application.yml\")) { New-Item \"$dir\\application.yml\" -ItemType File | Out-Null }",
    "persist": "application.yml",
    "checkver": {
        "url": "https://shinyproxy.io/downloads/",
        "regex": ">([\\d.]+)</h"
    },
