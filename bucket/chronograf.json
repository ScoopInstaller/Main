    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://dl.influxdata.com/chronograf/releases/chronograf-1.11.1_windows_amd64.zip",
            "hash": "2fbcd25f65d6c477fb108efa517c222255172bf29914c64c8b53a0696c5ddf99",
            "extract_dir": "chronograf-1.11.1-1"
        }
    },
    "bin": [
        "chronoctl.exe",
        "chronograf.exe"
    ],
    "checkver": {
        "url": "https://portal.influxdata.com/downloads",
        "regex": ">Chronograf v([\\d.]+)<"
    },
