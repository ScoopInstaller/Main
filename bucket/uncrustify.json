            "hash": "sha1:07173408278023ed12e3a3ed11e2248ef5e634e7"
        }
    },
    "bin": "bin\\uncrustify.exe",
    "checkver": {
        "sourceforge": "uncrustify",
        "regex": "uncrustify-(?<fver>[\\d.]+)/uncrustify-([\\d.]+)_"
    },
    "autoupdate": {
