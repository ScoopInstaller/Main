{
    "version": "0.113.1",
    "description": "A modern shell written in Rust",
    "homepage": "https://www.nushell.sh",
    "license": "MIT",
    "notes": [
        "Nushell's core plugins ship next to nu.exe but aren't registered, so 'plugin list' is empty by default.",
        "To register them, run the bundled helper in Nushell after installing or updating, then restart your shell:",
        "  nu ($nu.current-exe | path dirname | path join 'register-core-plugins.nu')"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/nushell/nushell/releases/download/0.113.1/nu-0.113.1-x86_64-pc-windows-msvc.zip",
            "hash": "fd3e56dac9f866d2d3fe2fabd6580c14371afdcec9ddda54624a50986d36b3d2"
        },
        "arm64": {
            "url": "https://github.com/nushell/nushell/releases/download/0.113.1/nu-0.113.1-aarch64-pc-windows-msvc.zip",
            "hash": "40acc9cb0006eb77534c4ff9ac8eba0d3464eb866217e28912804e4744f694e9"
        }
    },
    "post_install": [
        "$core = 'polars', 'formats', 'gstat', 'query', 'inc'",
        "$found = @(Get-ChildItem -LiteralPath $dir -Filter 'nu_plugin_*.exe').Count",
        "$present = @($core | Where-Object { Test-Path -LiteralPath \"$dir\\nu_plugin_$_.exe\" })",
        "$missing = @($core | Where-Object { $_ -notin $present })",
        "if (($found -ne 8) -or $missing) {",
        "    $detail = if ($missing) { \"; missing core: $($missing -join ', ')\" } else { '' }",
        "    Write-Host \"nu: bundled plugin set changed - found $found nu_plugin_*.exe, expected 8$detail. The manifest's core-plugin allowlist may need updating.\" -ForegroundColor Yellow",
        "}",
        "$helper = @(",
        "    '# Register Nushell core plugins, then restart your shell.'",
        "    \"for p in [$($present -join ' ')] {\"",
        "    '    plugin add ($nu.current-exe | path dirname | path join (''nu_plugin_'' + $p + ''.exe''))'",
        "    '}'",
        ")",
        "Set-Content -LiteralPath \"$dir\\register-core-plugins.nu\" -Value $helper -Encoding ascii"
    ],
    "bin": "nu.exe",
    "shortcuts": [
        [
            "nu.exe",
            "Nushell",
            "--execute \"cd ~\""
        ]
    ],
    "post_uninstall": [
        "if ($purge) {",
        "    $Directories = [string[]](",
        "        [System.IO.Path]::Combine($env:APPDATA,'nushell'),",
        "        [System.IO.Path]::Combine($env:LOCALAPPDATA,'nushell')",
        "    )",
        "    $Directories.ForEach{",
        "        if ([System.IO.Directory]::Exists($_)) {",
        "            $null = [System.IO.Directory]::Delete($_,$true)",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/nushell/nushell"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nushell/nushell/releases/download/$version/nu-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/nushell/nushell/releases/download/$version/nu-$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$baseurl/SHA256SUMS"
        }
    }
}
