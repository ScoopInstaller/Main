{
    "version": "0.14.2",
    "description": "A versatile and efficient proxy framework.",
    "homepage": "https://github.com/eycorsican/leaf",
    "license": "Apache-2.0",
    "suggest": {
        "wintun-dll": "wintun-dll"
    },
    "notes": [
        "Leaf needs wintun.dll to enable TUN inbound.",
        "You can install it first by running \"scoop install wintun-dll\",",
        "then reinstall leaf by running \"scoop uninstall leaf && scoop install leaf\"."
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/eycorsican/leaf/releases/download/v0.14.2/leaf-x86_64-pc-windows-gnu.zip",
            "hash": "d04705f049946473e117cff25b82b51bf3cbd421f484e041e390dd5ac640b59d",
            "bin": [
                [
                    "leaf-x86_64-pc-windows-gnu.exe",
                    "leaf"
                ]
            ]
        }
    },
    "installer": {
        "script": [
            "$getWintun = \"$(appdir wintun-dll)\\current\\wintun.dll\"",
            "if (Test-Path $getWintun) {",
            "Copy-Item -Path $getWintun -Destination $dir -Force",
            "}"
        ]
    },
    "uninstaller": {
        "script": [
            "$delWintun = \"$dir\\wintun.dll\"",
            "if (Test-Path $delWintun) {",
            "Remove-Item -Path $delWintun -Force",
            "}"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/eycorsican/leaf/releases/download/v$version/leaf-x86_64-pc-windows-gnu.zip"
            }
        }
    }
}
