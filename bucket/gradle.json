{
    "version": "9.6.1",
    "description": "An open-source build automation tool focused on flexibility and performance. (Source code and documentation bundled)",
    "homepage": "https://gradle.org",
    "license": "Apache-2.0",
    "suggest": {
        "JDK": "java/openjdk"
    },
    "url": "https://services.gradle.org/distributions/gradle-9.6.1-all.zip",
    "hash": "61ba77b3ff7167e60962763eb4bae79db7120c189b9544358d0ade3c1e712a83",
    "extract_dir": "gradle-9.6.1",
    "post_install": [
        "$current_env = Get-EnvVar -Name GRADLE_USER_HOME -Global:$global",
        "If ($null -eq $current_env) {",
        "    $path = \"$dir\\.gradle\"",
        "    Set-EnvVar -Name GRADLE_USER_HOME -Value $path -Global:$global",
        "    $Env:GRADLE_USER_HOME = $path",
        "    Write-Host \"Environment variable 'GRADLE_USER_HOME' set to '$path'\"",
        "}"
    ],
    "persist": ".gradle",
    "bin": "bin\\gradle.bat",
    "checkver": {
        "url": "https://services.gradle.org/versions/current",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://services.gradle.org/distributions/gradle-$version-all.zip",
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "gradle-$version"
    }
}
