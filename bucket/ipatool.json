{
    "version": "2.3.1",
    "description": "A command line tool that allows searching and downloading app packages (known as ipa files) from the iOS App Store.",
    "homepage": "https://github.com/majd/ipatool",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/majd/ipatool/releases/download/v2.3.1/ipatool-2.3.1-windows-amd64.tar.gz",
            "hash": "8e986ed9320f205bcd1fd24640ec46a5b92ff346425aff28d1103e57d2fdcadb"
        },
        "arm64": {
            "url": "https://github.com/majd/ipatool/releases/download/v2.3.1/ipatool-2.3.1-windows-arm64.tar.gz",
            "hash": "661ffbee49d25f46c463a2b38cd05b08048a4c939a194825b9e3316ad0867da9"
        }
    },
    "extract_dir": "bin",
    "pre_install": "Get-ChildItem \"$dir\\ipatool-*.exe\" | Select-Object -First 1 | Rename-Item -NewName \"ipatool.exe\"",
    "bin": "ipatool.exe",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/majd/ipatool/releases/download/v$version/ipatool-$version-windows-amd64.tar.gz"
            },
            "arm64": {
                "url": "https://github.com/majd/ipatool/releases/download/v$version/ipatool-$version-windows-arm64.tar.gz"
            }
        },
        "hash": {
            "url": "$url.sha256sum"
        }
    }
}
