{
    "version": "22.1.2",
    "description": "Collection of modular and reusable compiler and toolchain technologies. (arm64/aarch64 only)",
    "homepage": "https://www.llvm.org",
    "license": "NCSA",
    "architecture": {
        "arm64": {
            "url": "https://github.com/llvm/llvm-project/releases/download/llvmorg-22.1.2/LLVM-22.1.2-woa64.exe#/dl.7z",
            "hash": "77fbebfadd59f6e4d6068ee85fc271caf1f637eae2c0767246071c006c8f9b29"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall.exe\" -Recurse",
