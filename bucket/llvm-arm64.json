{
    "version": "22.1.7",
    "description": "Collection of modular and reusable compiler and toolchain technologies. (arm64/aarch64 only)",
    "homepage": "https://www.llvm.org",
    "license": "NCSA",
    "architecture": {
        "arm64": {
            "url": "https://github.com/llvm/llvm-project/releases/download/llvmorg-22.1.7/LLVM-22.1.7-woa64.exe#/dl.7z",
            "hash": "58a24275fdf10297a6cd794ec6a0ffd752dcf900ef33afdc9b7e91ff9041b65e"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall.exe\" -Recurse",
    "env_add_path": "bin",
    "env_set": {
        "LIBCLANG_PATH": "$dir\\bin",
        "LLVM_LIB_DIR": "$dir\\lib"
    },
    "checkver": {
        "github": "https://github.com/llvm/llvm-project",
        "regex": "llvmorg-([\\d._]+)"
    },
    "autoupdate": {
        "architecture": {
            "arm64": {
                "url": "https://github.com/llvm/llvm-project/releases/download/llvmorg-$version/LLVM-$version-woa64.exe#/dl.7z"
            }
        }
    }
