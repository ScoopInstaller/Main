{
    "version": "1.0.0",
    "description": "The terminal-first surface to interact with Antigravity agents.",
    "homepage": "https://antigravity.google/product/antigravity-cli",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://storage.googleapis.com/antigravity-public/antigravity-cli/1.0.0-5288553236791296/windows-x64/cli_windows_x64.exe#/agy.exe",
            "hash": "sha512:32a277541d61a3536e4b558bf17fc25625a92f72dbc2a7dc40edf4fbc300df73de88fe79f5b37d69303ceed31a95e30a83d235713097e66aeb086b8807aea16f"
        },
        "arm64": {
            "url": "https://storage.googleapis.com/antigravity-public/antigravity-cli/1.0.0-5288553236791296/windows-arm/cli_windows_arm64.exe#/agy.exe",
            "hash": "sha512:936ea0ce90700e5c78be9b520e49fbd7064ca20c793a16b7c49f8a8e254cdfbfd98ff781bf58a7f85f72f98006befc63054824a8d22672bc23a5ea02e45c5cfe"
        }
    },
    "bin": "agy.exe",
    "checkver": {
        "script": [
            "$install_script = (Invoke-RestMethod 'https://antigravity.google/cli/install.ps1')",
            "if($install_script -match '\\$DOWNLOAD_BASE_URL\\s*=\\s*\"(?<base>https://[^\"]+)\"') {",
            "    $base = $matches['base']",
            "    $manifest = (Invoke-RestMethod \"$base/manifests/windows_amd64.json\")",
            "    if($manifest.url -match '.*/antigravity-cli/(?<build>[^/]+)/') {",
            "        $v = $manifest.version",
            "        $b = $matches['build']",
            "        Write-Output \"$v $base $b\"",
            "    }",
            "}"
        ],
        "regex": "(?<version>[\\d.]+) (?<base>.*) (?<build>.*)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://storage.googleapis.com/antigravity-public/antigravity-cli/$matchBuild/windows-x64/cli_windows_x64.exe#/agy.exe",
                "hash": {
                    "url": "$matchBase/manifests/windows_amd64.json",
                    "jsonpath": "$.sha512"
                }
            },
            "arm64": {
                "url": "https://storage.googleapis.com/antigravity-public/antigravity-cli/$matchBuild/windows-arm/cli_windows_arm64.exe#/agy.exe",
                "hash": {
                    "url": "$matchBase/manifests/windows_arm64.json",
                    "jsonpath": "$.sha512"
                }
            }
        }
    }
}
