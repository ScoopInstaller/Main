    "hash": "1a221af6358b24b51a76224f405faf7d1784d2dd44639960887baa9744679c36",
    "pre_install": [
        "$cont = \"@echo off`r`n\" + 'cd /d \"%~dp0\"' + \"`r`njava -cp karate.jar;. com.intuit.karate.Main %*\"",
