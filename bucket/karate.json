    "homepage": "https://karatelabs.github.io/karate/",
    "license": "MIT",
    "suggest": {
        "Java": "java/openjdk"
    },
    "url": "https://github.com/karatelabs/karate/releases/download/v2.0.5/karate-2.0.5.jar#/karate.jar",
    "hash": "721a5753a747f1736228b457f389dbb7d9ae4555b2d82e16b1b228cf71fcdcbf",
    "pre_install": [
        "$cont = \"@echo off`r`n\" + 'cd /d \"%~dp0\"' + \"`r`njava -cp karate.jar;. com.intuit.karate.Main %*\"",
        "Set-Content \"$dir\\karate.bat\" $cont -Encoding ascii"
    ],
    "bin": "karate.bat",
    "persist": "target",
    "checkver": {
        "github": "https://github.com/karatelabs/karate"
    },
