    "pre_install": [
        "$cont = \"@echo off`r`n\" + 'cd /d \"%~dp0\"' + \"`r`njava -cp karate.jar;. com.intuit.karate.Main %*\"",
        "Set-Content \"$dir\\karate.bat\" $cont -Encoding ascii"
    ],
    "bin": "karate.bat",
    "persist": "target",
    "checkver": {
        "github": "https://github.com/karatelabs/karate"
    },
