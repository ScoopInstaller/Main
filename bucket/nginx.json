{
    "version": "1.31.1",
    "description": "An HTTP and reverse proxy server, a mail proxy server, and a generic TCP/UDP proxy server.",
    "homepage": "https://nginx.org",
    "license": "BSD-2-Clause",
    "notes": "To use the correct configuration run 'nginx -p \"$env:NGINX_HOME\"' or 'nginx -p \"%NGINX_HOME%\"'",
    "url": "https://nginx.org/download/nginx-1.31.1.zip",
    "hash": "f0d674c529623f678b272e66ffa40c1f9e72763e21e323d3dfad465d8b10abb1",
    "extract_dir": "nginx-1.31.1",
    "bin": "nginx.exe",
    "env_set": {
        "NGINX_HOME": "$dir"
    },
    "persist": [
        "conf",
        "html",
        "logs",
        "temp"
    ],
    "checkver": {
        "url": "https://nginx.org/en/CHANGES",
        "regex": "Changes with nginx ([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://nginx.org/download/nginx-$version.zip",
        "extract_dir": "nginx-$version"
    }
}
