        },
        "32bit": {
            "url": "https://mirror.racket-lang.org/installers/9.2/racket-minimal-9.2-i386-win32.exe#/dl.7z",
            "hash": "2ebbe1fdf7136775580249efe2c1bc5e9a765fa87205fe75f39ac134fff349f3"
        },
        "arm64": {
            "url": "https://mirror.racket-lang.org/installers/9.2/racket-minimal-9.2-arm64-win32.exe#/dl.7z",
