{
    "version": "0.11.32",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://docs.astral.sh/uv/",
    "license": "Apache-2.0|MIT",
    "notes": [
        "Scoop persists data since version 0.11.16. You may need to move data by yourself.",
        "Before: '$env:APPDATA\\uv', '$env:LOCALAPPDATA\\uv'",
        "After : '$persist_dir'"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.32/uv-x86_64-pc-windows-msvc.zip",
            "hash": "acfde570451cfdb8689fa159a138ee805ba4e241c466432750302c86254b0984"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.32/uv-i686-pc-windows-msvc.zip",
            "hash": "e54e814a3963af3af607940f142169312d7550d44db8e2daa2bf6c524554ac3c"
        },
        "arm64": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.32/uv-aarch64-pc-windows-msvc.zip",
            "hash": "a7427ea0440bb826b6716d1837ff3d173b8e7d496cb09ee8f456b4e023a2fdcd"
        }
    },
    "installer": {
        "script": [
            "Add-Path -Path \"$persist_dir\\python\\shims\" -Global:$global -Force",
            "Add-Path -Path \"$persist_dir\\tools\\shims\" -Global:$global -Force"
        ]
    },
    "env_set": {
        "UV_CACHE_DIR": "$persist_dir\\cache",
        "UV_PYTHON_BIN_DIR": "$persist_dir\\python\\shims",
        "UV_PYTHON_INSTALL_DIR": "$persist_dir\\python\\versions",
        "UV_TOOL_BIN_DIR": "$persist_dir\\tools\\shims",
        "UV_TOOL_DIR": "$persist_dir\\tools\\versions"
    },
    "bin": [
        "uv.exe",
        "uvx.exe",
        "uvw.exe"
    ],
    "uninstaller": {
        "script": [
            "$global = installed $app $true",
            "Remove-Path -Path \"$persist_dir\\tools\\shims\" -Global:$global -Force",
            "Remove-Path -Path \"$persist_dir\\python\\shims\" -Global:$global -Force"
        ]
    },
    "checkver": {
        "github": "https://github.com/astral-sh/uv"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-i686-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
