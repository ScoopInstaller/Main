    "checkver": {
        "github": "https://api.github.com/repos/neovim/neovim/releases/latest",
        "jsonpath": "$.body",
        "regex": "NVIM v(?<majorVersion>[\\w.-]+)\\.(?<minorVersion>[\\w.-]+)\\.(?<patchVersion>[\\w.-]+)",
        "replace": "${majorVersion}.${minorVersion}.${patchVersion}"
    },
