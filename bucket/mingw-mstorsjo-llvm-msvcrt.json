    "license": "GPL-3.0-or-later,ZPL-2.1,Apache-2.0 WITH LLVM-exception,ISC",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mstorsjo/llvm-mingw/releases/download/20260602/llvm-mingw-20260602-msvcrt-x86_64.zip",
            "hash": "a7d44091c4a362cfd13ad5f86541f8c91a85b96e4aae03c29995cda4a2214928",
            "extract_dir": "llvm-mingw-20260602-msvcrt-x86_64"
        },
        "32bit": {
            "url": "https://github.com/mstorsjo/llvm-mingw/releases/download/20260602/llvm-mingw-20260602-msvcrt-i686.zip",
