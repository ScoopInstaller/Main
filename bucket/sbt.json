{
    "version": "2.0.1",
    "description": "A build tool for Scala, Java, and more",
    "homepage": "https://www.scala-sbt.org",
    "license": "BSD-3-Clause",
    "url": "https://github.com/sbt/sbt/releases/download/v2.0.1/sbt-2.0.1.zip",
    "hash": "7e689998c1c6870fbea9f2597e414431e3ba0195c3f80a0f602d528011e85160",
    "extract_dir": "sbt",
    "env_set": {
        "SBT_HOME": "$dir"
    },
    "bin": "bin\\sbt.bat",
    "persist": "conf",
    "checkver": {
        "url": "https://www.scala-sbt.org/download/",
        "regex": "/sbt-([\\d.]+)\\.zip"
    },
    "autoupdate": {
        "url": "https://github.com/sbt/sbt/releases/download/v$version/sbt-$version.zip",
        "hash": {
            "url": "$url.sha256"
        }
    }
}
