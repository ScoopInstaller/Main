{
    "version": "2.0.3",
    "description": "A build tool for Scala, Java, and more",
    "homepage": "https://www.scala-sbt.org",
    "license": "BSD-3-Clause",
    "url": "https://github.com/sbt/sbt/releases/download/v2.0.3/sbt-2.0.3.zip",
    "hash": "f85f15467222b38e57fa346cf82d3c2c0d680a39c1ba997627739772ce5462d8",
    "extract_dir": "sbt",
    "env_set": {
        "SBT_HOME": "$dir"
    },
    "bin": "bin\\sbt.bat",
    "persist": "conf",
    "checkver": {
        "url": "https://www.scala-sbt.org/download/",
        "regex": "/sbt-([\\d.]+)\\.zip"
    },
    "autoupdate": {
        "url": "https://github.com/sbt/sbt/releases/download/v$version/sbt-$version.zip",
        "hash": {
            "url": "$url.sha256"
        }
    }
}
