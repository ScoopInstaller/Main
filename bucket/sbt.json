{
    "version": "2.0.0",
    "description": "A build tool for Scala, Java, and more",
    "homepage": "https://www.scala-sbt.org",
    "license": "BSD-3-Clause",
    "url": "https://github.com/sbt/sbt/releases/download/v2.0.0/sbt-2.0.0.zip",
    "hash": "f9e5fbde57b5c8d926bfc1f221847d8a90e1411ace2aae392299baeaea464587",
    "extract_dir": "sbt",
    "env_set": {
        "SBT_HOME": "$dir"
    },
    "bin": "bin\\sbt.bat",
    "persist": "conf",
    "checkver": {
        "url": "https://www.scala-sbt.org/download/",
        "regex": "/sbt-([\\d.]+)\\.zip"
    },
    "autoupdate": {
        "url": "https://github.com/sbt/sbt/releases/download/v$version/sbt-$version.zip",
        "hash": {
            "url": "$url.sha256"
        }
    }
}
