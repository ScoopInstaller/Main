{
    "version": "2.0.2",
    "description": "A build tool for Scala, Java, and more",
    "homepage": "https://www.scala-sbt.org",
    "license": "BSD-3-Clause",
    "url": "https://github.com/sbt/sbt/releases/download/v2.0.2/sbt-2.0.2.zip",
    "hash": "c25cb66f3c68700e79ff73add7efadf9099e8e123a476f153aaafdbb5a94426a",
    "extract_dir": "sbt",
    "env_set": {
        "SBT_HOME": "$dir"
    },
    "bin": "bin\\sbt.bat",
    "persist": "conf",
    "checkver": {
        "url": "https://www.scala-sbt.org/download/",
        "regex": "/sbt-([\\d.]+)\\.zip"
    },
    "autoupdate": {
        "url": "https://github.com/sbt/sbt/releases/download/v$version/sbt-$version.zip",
        "hash": {
            "url": "$url.sha256"
        }
    }
}
