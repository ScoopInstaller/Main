    "license": "BSD-3-Clause",
    "url": "https://github.com/sbt/sbt/releases/download/v1.12.8/sbt-1.12.8.zip",
    "hash": "f36fbc74a4658ba9aa8e7b76faa295307ee853a1816896820fd12b8df34cf780",
    "extract_dir": "sbt",
