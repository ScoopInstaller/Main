    "license": "BSD-3-Clause",
    "url": "https://github.com/sbt/sbt/releases/download/v1.12.11/sbt-1.12.11.zip",
    "hash": "79930e2d63cbed0e8fd6e4399dca57da86a33a1840f3cdc353f6a62446ccb1b9",
    "extract_dir": "sbt",
    "env_set": {
        "SBT_HOME": "$dir"
    },
    "bin": "bin\\sbt.bat",
