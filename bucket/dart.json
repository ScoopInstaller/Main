{
    "version": "3.11.5",
    "description": "SDK for the Dart programming language",
    "homepage": "https://dart.dev/",
    "license": "BSD-3-Clause",
    "extract_dir": "dart-sdk",
    "env_add_path": "bin",
    "architecture": {
        "64bit": {
            "url": "https://storage.googleapis.com/dart-archive/channels/stable/release/3.11.5/sdk/dartsdk-windows-x64-release.zip",
            "hash": "044b9c58f45c7e8b67467395eaad469f67cd8797a73fbd1d2bb8a89a53b2dcba"
        }
    },
    "checkver": {
        "url": "https://storage.googleapis.com/dart-archive/channels/stable/release/latest/VERSION",
