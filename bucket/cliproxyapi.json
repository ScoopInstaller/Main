    "homepage": "https://help.router-for.me",
    "license": "MIT",
    "notes": [
        "cli-proxy-api shim use \"$persist_dir\\config.yaml\" as the default config file.",
        "To use a different config file, please run:",
        "\"$dir\\cli-proxy-api.exe\" --config <NEW_CONFIG_FILE>"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.1.56/CLIProxyAPI_7.1.56_windows_amd64.zip",
            "hash": "34dc0a3948777fa4b55e0d1c2986614896a6f974117dd0c53577e8ef62e6055e"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.1.56/CLIProxyAPI_7.1.56_windows_aarch64.zip",
            "hash": "a2304d656a30b595288aa4c781b740c172af9bdcb4a5419002f946d9c8dc4713"
        }
    },
    "pre_install": [
        "if (-not (Test-Path -Path \"$persist_dir\\config.yaml\")) {",
        "    Copy-Item -Path \"$dir\\config.example.yaml\" -Destination \"$dir\\config.yaml\"",
        "}"
    ],
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "--config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": "config.yaml",
    "checkver": {
        "github": "https://github.com/router-for-me/CLIProxyAPI"
    },
    "autoupdate": {
