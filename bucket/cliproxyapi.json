    "license": "MIT",
    "notes": [
        "cli-proxy-api shim use \"$persist_dir\\config.yaml\" as the default config file.",
        "To use a different config file, please run:",
        "\"$dir\\cli-proxy-api.exe\" --config <NEW_CONFIG_FILE>"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.55/CLIProxyAPI_7.2.55_windows_amd64.zip",
            "hash": "b912efeec4284e8f04c0328f2a89ed0d15060c4349ad2e224e831f7f451f0f9a"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.55/CLIProxyAPI_7.2.55_windows_aarch64.zip",
            "hash": "ad630fd6473cea902a602d7bf6707a027360919743130383b7cd94328969b081"
        }
    },
    "pre_install": [
        "if (-not (Test-Path -Path \"$persist_dir\\config.yaml\")) {",
        "    Copy-Item -Path \"$dir\\config.example.yaml\" -Destination \"$dir\\config.yaml\"",
        "}"
    ],
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "--config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": "config.yaml",
    "checkver": {
        "github": "https://github.com/router-for-me/CLIProxyAPI"
    },
    "autoupdate": {
