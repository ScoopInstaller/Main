    "homepage": "https://help.router-for.me",
    "license": "MIT",
    "notes": [
        "cli-proxy-api shim use \"$persist_dir\\config.yaml\" as the default config file.",
        "To use a different config file, please run:",
        "\"$dir\\cli-proxy-api.exe\" --config <NEW_CONFIG_FILE>"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.43/CLIProxyAPI_7.2.43_windows_amd64.zip",
            "hash": "29a72f85dd0c39cfa7c2043da3f41931b1088e498bbd2b726a2a8e0dc22fd95d"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.43/CLIProxyAPI_7.2.43_windows_aarch64.zip",
            "hash": "7f6088e82501531b1a50ffd8435516863c296d38752c4a5401c9c5745afaf9f9"
        }
    },
    "pre_install": [
        "if (-not (Test-Path -Path \"$persist_dir\\config.yaml\")) {",
        "    Copy-Item -Path \"$dir\\config.example.yaml\" -Destination \"$dir\\config.yaml\"",
        "}"
    ],
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "--config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": "config.yaml",
    "checkver": {
        "github": "https://github.com/router-for-me/CLIProxyAPI"
    },
    "autoupdate": {
