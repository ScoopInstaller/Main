    "license": "MIT",
    "notes": [
        "cli-proxy-api shim use \"$persist_dir\\config.yaml\" as the default config file.",
        "To use a different config file, please run:",
        "\"$dir\\cli-proxy-api.exe\" --config <NEW_CONFIG_FILE>"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.42/CLIProxyAPI_7.2.42_windows_amd64.zip",
            "hash": "cb6557ad38aef485c56c769fa53e2a5f8a8a4f50e158e979a38a8cfc5b51fe19"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.42/CLIProxyAPI_7.2.42_windows_aarch64.zip",
            "hash": "0941498a68016c5c9ea9ae1f9fccb60f207e01905950f4cc939b3f5e53628dd9"
        }
    },
    "pre_install": [
        "if (-not (Test-Path -Path \"$persist_dir\\config.yaml\")) {",
        "    Copy-Item -Path \"$dir\\config.example.yaml\" -Destination \"$dir\\config.yaml\"",
        "}"
    ],
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "--config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": "config.yaml",
    "checkver": {
        "github": "https://github.com/router-for-me/CLIProxyAPI"
    },
