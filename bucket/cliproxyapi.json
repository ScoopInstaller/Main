    "homepage": "https://help.router-for.me",
    "license": "MIT",
    "notes": [
        "cli-proxy-api shim use \"$persist_dir\\config.yaml\" as the default config file.",
        "To use a different config file, please run:",
        "\"$dir\\cli-proxy-api.exe\" --config <NEW_CONFIG_FILE>"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.44/CLIProxyAPI_7.2.44_windows_amd64.zip",
            "hash": "36563f9f44f6791c146626d682f488a18bd052ee689e4abd878b7e4603001a07"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.44/CLIProxyAPI_7.2.44_windows_aarch64.zip",
            "hash": "98927fca02a0d05f2fea0454a173b11bc307bc7e27e9ca40e85800b075aaef2e"
        }
    },
    "pre_install": [
        "if (-not (Test-Path -Path \"$persist_dir\\config.yaml\")) {",
        "    Copy-Item -Path \"$dir\\config.example.yaml\" -Destination \"$dir\\config.yaml\"",
        "}"
    ],
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "--config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": "config.yaml",
    "checkver": {
        "github": "https://github.com/router-for-me/CLIProxyAPI"
    },
