{
    "version": "4.1.2",
    "description": "A unified analytics engine for large-scale data processing.",
    "homepage": "https://spark.apache.org/",
    "license": "Apache-2.0",
    "notes": "Spark now comes with Hadoop 3. For the version with Hadoop 2, please install spark-hadoop2 from the Versions bucket.",
    "suggest": {
        "JDK": "java/openjdk"
    },
    "url": "https://archive.apache.org/dist/spark/spark-4.1.2/spark-4.1.2-bin-hadoop3.tgz",
    "hash": "sha512:490510e13e97da9493302bb33a802574bc417fcc107441419d1a0f87f2b372000db6e26f831a2bf92bc4b18bdf2c9023b1b6f2d021afdc7d6c19c8a11c03e685",
    "extract_dir": "spark-4.1.2-bin-hadoop3",
    "env_add_path": "bin",
    "env_set": {
        "SPARK_HOME": "$dir"
    },
    "persist": "conf",
    "checkver": {
        "url": "https://spark.apache.org/js/downloads.js",
        "regex": "addRelease\\(\"([\\d.]+)\","
    },
    "autoupdate": {
        "url": "https://archive.apache.org/dist/spark/spark-$version/spark-$version-bin-hadoop3.tgz",
        "hash": {
            "url": "$url.sha512",
            "regex": "$basename: ([A-F0-9\\s]+)$"
        },
        "extract_dir": "spark-$version-bin-hadoop3"
    }
}
