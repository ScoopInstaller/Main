{
    "version": "4.2.0",
    "description": "A unified analytics engine for large-scale data processing.",
    "homepage": "https://spark.apache.org/",
    "license": "Apache-2.0",
    "notes": "Spark now comes with Hadoop 3. For the version with Hadoop 2, please install spark-hadoop2 from the Versions bucket.",
    "suggest": {
        "JDK": "java/openjdk"
    },
    "url": "https://archive.apache.org/dist/spark/spark-4.2.0/spark-4.2.0-bin-hadoop3.tgz",
    "hash": "sha512:3a6559e8546ff387db8fe7a04b8fe4008853b467b972c2e343df8e14a81450534777719fc5d4998dd96519a86fdf9de140cee753c61e2e94db044d5f9555ddc4",
    "extract_dir": "spark-4.2.0-bin-hadoop3",
    "env_add_path": "bin",
    "env_set": {
        "SPARK_HOME": "$dir"
    },
    "persist": "conf",
    "checkver": {
        "url": "https://spark.apache.org/js/downloads.js",
        "regex": "addRelease\\(\"([\\d.]+)\","
    },
    "autoupdate": {
        "url": "https://archive.apache.org/dist/spark/spark-$version/spark-$version-bin-hadoop3.tgz",
        "hash": {
            "url": "$url.sha512",
            "regex": "$basename: ([A-F0-9\\s]+)$"
        },
        "extract_dir": "spark-$version-bin-hadoop3"
    }
}
